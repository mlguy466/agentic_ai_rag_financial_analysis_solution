AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_RESOURCE_GROUP="<your-resource-group>"
AZURE_LOCATION="eastus"

AZURE_OPENAI_ENDPOINT="https://<your-openai-resource>.openai.azure.com"
AZURE_OPENAI_MODEL="<your-openai-deployment-name>"
AZURE_OPENAI_API_KEY=

AZURE_SEARCH_ENDPOINT="https://<your-search-service>.search.windows.net"
AZURE_SEARCH_INDEX_NAME="financial-filings"
# Optional: only needed if you want key-based auth instead of az login / Entra ID.
AZURE_SEARCH_API_KEY=

AZURE_STORAGE_ACCOUNT_URL="https://<your-storage-account>.blob.core.windows.net"
AZURE_STORAGE_CONTAINER=filings

AZURE_KEY_VAULT_URL="https://<your-vault-name>.vault.azure.net"
